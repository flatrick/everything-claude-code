{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MDT Claude Plugin Manifest Reference",
  "description": "Reference schema for .claude-plugin/plugin.json. Claude's real plugin validator has additional undocumented rules; see .claude-plugin/PLUGIN_SCHEMA_NOTES.md.",
  "type": "object",
  "required": ["name", "version"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "description": { "type": "string" },
    "author": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          },
          "required": ["name"]
        }
      ]
    },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string" },
    "license": { "type": "string" },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hooks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reference only. Do not declare the default hooks/hooks.json file here; Claude loads it automatically."
    },
    "mcp_configs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
